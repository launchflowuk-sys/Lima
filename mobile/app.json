{
  "expo": {
    "name": "Agent Lima",
    "slug": "launchflow-inbox",
    "scheme": "launchflowinbox",
    "owner": "shoji147",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0A1526",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05070C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.launchflow.inbox",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.launchflow.inbox",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundImage": "./assets/images/adaptive-bg.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://agentlima.com",
      "router": {},
      "eas": {
        "projectId": "d341b11d-6ae8-43f5-870f-27a2ffc17ca6"
      }
    }
  }
}
